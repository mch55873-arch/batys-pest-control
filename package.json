{
  "name": "pest-control-seo",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "cf:build": "opennextjs-cloudflare build --dangerouslyUseUnsupportedNextVersion",
    "worker:assets": "node scripts/build-worker-assets.mjs",
    "worker:build": "npm run cf:build && npm run worker:assets",
    "preview": "opennextjs-cloudflare build --dangerouslyUseUnsupportedNextVersion && opennextjs-cloudflare preview",
    "deploy": "npm run worker:build && wrangler deploy"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@types/papaparse": "^5.5.2",
    "autoprefixer": "^10.5.4",
    "eslint-config-next": "16.2.11",
    "next": "16.2.11",
    "papaparse": "^5.5.4",
    "postcss": "^8.5.20",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "tailwindcss": "^3.4.19",
    "typescript": "^5",
    "wrangler": "^4.112.0"
  }
}
